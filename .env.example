# * 站点地址
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# * Better Auth 配置 (GitHub 登录需要)
# * 生成密钥: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# * 管理员邮箱，用于后台权限控制
NEXT_PUBLIC_ADMIN_EMAILS="example@gmail.com"

# * 管理员钱包地址 (可选，用于 Web3 登录)
NEXT_PUBLIC_ADMIN_WALLET_ADDRESS=""

# * GitHub OAuth 配置 (用于登录)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# * Google OAuth 配置 (用于登录)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# * UploadThing 图片上传配置
UPLOADTHING_TOKEN=

# * PostgreSQL 数据库地址
DATABASE_URL=

# * 邮件通知 SMTP 配置
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
# Gmail 应用专用密码可以不写空格，代码也会自动移除空白
SMTP_PASS=
MAIL_FROM="叶鱼博客 <notice@example.com>"
# 站长通知收件人，多个邮箱用英文逗号分隔
MAIL_TO=
